# MySQL Database configuration
# The password for your local MySQL database 'root' user
DB_PASSWORD=your_mysql_root_password_here

# JWT Security
# A secure signing key of at least 32 characters (256 bits) for signing JSON Web Tokens
JWT_SECRET=change_me_to_a_secure_random_string_of_at_least_32_chars

# Admin registration and authorization secret
# Secret token key passed in 'X-Admin-Secret' header for admin registration
ADMIN_SECRET=change_me_to_a_secure_admin_registration_key
